#include <HardwareSerial.h>

HardwareSerial gsm(2);

void setup() {

  Serial.begin(115200);

  gsm.begin(9600, SERIAL_8N1, 16, 17);

  delay(3000);

  sendSMS();
}

void loop() {

}

void sendSMS() {

  gsm.println("AT");
  delay(1000);

  gsm.println("AT+CMGF=1"); // TEXT MODE
  delay(1000);

  gsm.println("AT+CMGS=\"+2507XXXXXXXX\""); // YOUR NUMBER
  delay(1000);

  gsm.print("Hello! Motion detected on ESP32 security system");
  delay(1000);

  gsm.write(26); // CTRL+Z TO SEND

  delay(5000);

  Serial.println("SMS Sent!");
}
